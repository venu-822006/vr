# VR Vegetables - Root Environment Config
# This file is loaded automatically by docker-compose for local development.
# When deploying to production (Vercel, Render), you must set these variables in the respective platforms.

# ─── Auth ───
# Generate strong secrets for production
JWT_SECRET=local-dev-jwt-secret
JWT_REFRESH_SECRET=local-dev-refresh-secret

# ─── Deployment URLs ───
CORS_ORIGIN=http://localhost:5173
# For Vercel, set API_URL in the Vercel dashboard pointing to your Render URL.

# ─── Database & Cache (Docker Local Overrides) ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vrveg

# ─── Object Storage (MinIO Local Overrides) ───
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vr-vegetables
S3_REGION=us-east-1

# ─── Push Notifications (Optional) ───
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
