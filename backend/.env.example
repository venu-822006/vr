# VR Vegetables Backend Environment Config
# These variables should be configured in your Render Blueprint (render.yaml).

NODE_ENV=production
PORT=3001

# ─── Auth Secrets ───
JWT_SECRET=production-secret-change-me
JWT_REFRESH_SECRET=production-secret-change-me

# ─── CORS ───
# Update this to your deployed Vercel URL
CORS_ORIGIN=http://localhost:5173

# ─── Database (Supabase) ───
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ─── Cache & Queue (Upstash) ───
# Format: rediss://default:[password]@[region].upstash.io:[port]
REDIS_URL=

# ─── Image Storage (Cloudflare R2) ───
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vr-vegetables

# ─── Push Notifications (Optional) ───
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
